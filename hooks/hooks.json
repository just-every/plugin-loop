{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/scripts/user-prompt-submit.js",
            "timeoutSec": 1200,
            "statusMessage": "Fable is reviewing the loop prompt"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/scripts/stop.js",
            "timeoutSec": 1200,
            "statusMessage": "Fable is checking whether the goal is met"
          }
        ]
      }
    ]
  }
}
